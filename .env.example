ENV=development

SUPABASE_HOST=db.your-project-ref.supabase.co
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

N8N_POSTGRES_USER=n8n_admin
N8N_POSTGRES_PASSWORD=change-me

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_ROLE=admin
SETUP_DB_RESET=false

DATABASE_URL=postgresql+psycopg://postgres:change-me@db.your-project-ref.supabase.co:5432/postgres
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173,http://localhost
COOKIE_REFRESH_NAME=refresh_token
LOG_LEVEL=INFO

N8N_DB_NAME=n8n
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_TOKEN=change-me

# URL completa del webhook de n8n que dispara la sincronización de Notion
N8N_WEBHOOK_URL=https://sistemas-rtb.app.n8n.cloud/webhook/812c98dc-1570-4e00-a0e0-916057707a7c

# Clave secreta que n8n incluye en el header x-sync-key al enviar CSVs al backend
SYNC_API_KEY=change-me

CLOUDFLARE_TUNNEL_NAME=change-me
CLOUDFLARE_HOSTNAME=example.your-domain.com

VITE_API_URL=http://localhost:8000
VITE_APP_NAME=Nexus Ops RTB
VITE_ENV=development
VITE_POLL_INTERVAL_MS=10000
